#!/bin/sh
set -e

repo_root="$(git rev-parse --show-toplevel)"

if command -v bash >/dev/null 2>&1; then
  bash "$repo_root/scripts/sync-skills.sh"
  exit 0
fi

if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/sync-skills.ps1"
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "$repo_root/scripts/sync-skills.ps1"
  exit 0
fi

echo "No supported shell found for skill sync" >&2
exit 1